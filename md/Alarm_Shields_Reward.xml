<?xml version="1.0" encoding="utf-8"?>
<mdscript name="Alarm_Shields_Reward" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="md.xsd">
  <!-- Generated by X4 Foundations Mod Studio (version 1.0.0) -->
  <!-- Author: AgentTest -->
  <!-- Description: Plays alarm, lowers shields, rewards 100k credits when player enters a new sector. -->
  <cues>
    <cue name="Alarm_Shields_Reward" instantiate="true" namespace="this">
      <conditions>
        <event_object_changed_sector object="playership" sector="player.sector" />
      </conditions>
      <actions>
        <play_sound object="playership" sound="alarm_red" />
        <set_object_shieldlevel object="player.primaryship" level="0" comment="Drop shields to zero" />
        <reward_player money="1000000" notification="true">
        </reward_player>
      </actions>
    </cue>
  </cues>
</mdscript>